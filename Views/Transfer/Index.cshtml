@model AltLigMenajer.Models.TransferHubViewModel
@{
    ViewData["Title"] = "Transfer Hub";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var managerName = $"{Model.Manager.FirstName} {Model.Manager.LastName}";
    bool isWindowOpen = ViewBag.IsTransferWindowOpen ?? true;
}
@section Styles {
<style>
.glass-panel { background: rgba(38,38,38,0.6); backdrop-filter: blur(20px); }
.text-glow-primary { text-shadow: 0 0 10px rgba(142,255,113,0.5); }
.stadium-gradient { background: radial-gradient(circle at top right,rgba(142,255,113,0.05),transparent 60%); }
.filter-active { background: var(--md-sys-color-primary) !important; color: var(--md-sys-color-on-primary-fixed) !important; font-weight: 700; }
.scout-pulse { animation: pulse-scout 2s infinite; }
@@keyframes pulse-scout { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
</style>
}

<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 flex justify-between items-center px-6 py-4 bg-gradient-to-b from-[#0e0e0e] to-transparent">
    <div class="flex items-center gap-4">
        <div class="flex flex-col">
            <h1 class="font-headline text-primary font-bold tracking-tighter uppercase leading-none">TRANSFER HUB</h1>
            <div class="flex flex-col mt-1">
                <span class="font-label text-[10px] text-on-surface-variant uppercase tracking-widest leading-none">@managerName - PRO LICENSE</span>
                <span class="font-label text-[12px] text-on-surface font-bold tracking-tight">@Model.MyTeam.Name</span>
            </div>
        </div>
    </div>
    <div class="flex flex-col gap-1 items-end">
        <div class="bg-surface-container-high/80 px-4 py-1.5 rounded-lg border-r-4 border-primary shadow-lg flex flex-col items-end min-w-[140px]">
            <span class="font-label text-[9px] text-on-surface-variant uppercase tracking-tighter">TRANSFER BÜTÇESİ</span>
            <span class="font-headline text-primary font-bold text-lg leading-none">@Model.MyTeam.Budget.ToString("N0") €</span>
        </div>
    </div>
</header>

<main class="pt-28 px-4 md:px-6 pb-32 max-w-7xl mx-auto stadium-gradient">

    <!-- Toast Notifications -->
    @if (TempData["TransferError"] != null)
    {
        <div id="transfer-toast" class="fixed top-5 left-1/2 -translate-x-1/2 bg-error text-white px-6 py-3 rounded-full font-headline font-bold shadow-[0_0_20px_rgba(0,0,0,0.5)] z-[100] transition-opacity duration-300">
            @TempData["TransferError"]
        </div>
    }
    @if (TempData["TransferSuccess"] != null)
    {
        <div id="transfer-toast" class="fixed top-5 left-1/2 -translate-x-1/2 bg-primary text-on-primary-fixed px-6 py-3 rounded-full font-headline font-bold shadow-[0_0_20px_rgba(0,0,0,0.5)] z-[100] transition-opacity duration-300">
            @TempData["TransferSuccess"]
        </div>
    }

    @if (!isWindowOpen)
    {
        <div class="mb-6 bg-error/10 border border-error/30 rounded-2xl p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-error/20 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-error text-2xl">block</span>
            </div>
            <div>
                <h3 class="font-headline font-bold text-error text-lg">TRANSFER DÖNEMİ KAPALI</h3>
                <p class="font-label text-sm text-on-surface-variant mt-0.5">Yaz dönemi: 30 Haziran - 15 Eylül | Kış dönemi: 1 - 31 Ocak</p>
            </div>
        </div>
    }

    <!-- Search & Filter Bar -->
    <section class="mb-8">
        <form method="get" asp-action="Index" asp-controller="Transfer" class="flex flex-col md:flex-row gap-4 items-center">
            <div class="relative w-full md:w-1/3 group">
                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary transition-colors">search</span>
                <input name="search" value="@Model.SearchQuery" class="w-full bg-surface-container-high border-none rounded-xl py-4 pl-12 pr-4 font-label text-sm tracking-widest focus:ring-2 focus:ring-primary/30 text-on-surface placeholder:text-outline transition-all" placeholder="OYUNCU ARA..." type="text" />
                @if (!string.IsNullOrEmpty(Model.ActiveFilter))
                {
                    <input type="hidden" name="filter" value="@Model.ActiveFilter" />
                }
            </div>
            <div class="flex flex-wrap gap-2 w-full md:w-2/3">
                <a href="@Url.Action("Index", "Transfer")" class="px-5 py-3 rounded-xl font-label text-xs uppercase tracking-wider hover:scale-95 transition-transform active:scale-90 border border-outline-variant/10 @(Model.ActiveFilter == null ? "filter-active" : "bg-surface-container-high text-on-surface-variant hover:bg-surface-bright")">Tüm Oyuncular</a>
                <a href="@Url.Action("Index", "Transfer", new { filter = "young", search = Model.SearchQuery })" class="px-5 py-3 rounded-xl font-label text-xs uppercase tracking-wider hover:scale-95 transition-transform border border-outline-variant/10 @(Model.ActiveFilter == "young" ? "filter-active" : "bg-surface-container-high text-on-surface-variant hover:bg-surface-bright")">Yaş: 17-25</a>
                <a href="@Url.Action("Index", "Transfer", new { filter = "budget", search = Model.SearchQuery })" class="px-5 py-3 rounded-xl font-label text-xs uppercase tracking-wider hover:scale-95 transition-transform border border-outline-variant/10 @(Model.ActiveFilter == "budget" ? "filter-active" : "bg-surface-container-high text-on-surface-variant hover:bg-surface-bright")">Bütçe İçi</a>
                <a href="@Url.Action("Index", "Transfer", new { filter = "scouted", search = Model.SearchQuery })" class="px-5 py-3 rounded-xl font-label text-xs uppercase tracking-wider hover:scale-95 transition-transform border border-outline-variant/10 @(Model.ActiveFilter == "scouted" ? "filter-active" : "bg-surface-container-high text-on-surface-variant hover:bg-surface-bright")">Gözlemlenenler</a>
                <button type="submit" class="ml-auto w-12 h-12 flex items-center justify-center rounded-xl bg-primary text-on-primary-fixed hover:brightness-110 transition-colors">
                    <span class="material-symbols-outlined">search</span>
                </button>
            </div>
        </form>
    </section>

    <!-- Player Cards Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        @if (Model.AvailablePlayers.Count == 0)
        {
            <div class="col-span-full flex flex-col items-center justify-center py-20 text-on-surface-variant">
                <span class="material-symbols-outlined text-6xl mb-4 opacity-30">person_search</span>
                <p class="font-headline text-lg font-bold">Oyuncu Bulunamadı</p>
                <p class="font-label text-sm mt-1">Arama kriterlerinizi değiştirin.</p>
            </div>
        }
        @foreach (var player in Model.AvailablePlayers)
        {
            var scoutReport = Model.ScoutReports.FirstOrDefault(r => r.PlayerId == player.Id);
            var isScouted = scoutReport?.IsCompleted == true;
            var isScoutPending = scoutReport != null && !scoutReport.IsCompleted;
            var daysRemaining = isScoutPending ? (scoutReport!.CompletionDate - Model.CurrentDate).Days : 0;
            if (daysRemaining < 0) daysRemaining = 0;

            var ovrDashOffset = 175.9 - (175.9 * player.Ovr / 100.0);
            var potDashOffset = isScouted ? (175.9 - (175.9 * player.Potential / 100.0)) : 0;

            var sellingTeam = player.Team;

            <div class="group relative overflow-hidden rounded-3xl bg-surface-container-high p-1 transition-all @(isScouted ? "hover:shadow-[0_0_40px_rgba(142,255,113,0.1)]" : "hover:shadow-[0_0_40px_rgba(255,183,71,0.05)]")">
                <div class="relative z-10 bg-surface-container-high rounded-[calc(1.5rem-4px)] p-5 h-full flex flex-col sm:flex-row gap-5">
                    <!-- Player Image / Placeholder -->
                    <div class="relative w-full sm:w-40 aspect-[3/4] rounded-2xl overflow-hidden bg-[#1a1a1a] flex-shrink-0">
                        @if (isScouted)
                        {
                            <div class="w-full h-full flex items-center justify-center">
                                <span class="material-symbols-outlined text-6xl text-primary/40">person</span>
                            </div>
                        }
                        else
                        {
                            <div class="w-full h-full flex items-center justify-center">
                                <span class="material-symbols-outlined text-6xl text-outline-variant/30">person_search</span>
                            </div>
                        }
                        <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60"></div>
                        <div class="absolute bottom-0 left-0 w-full p-3">
                            <span class="@(isScouted ? "bg-primary text-on-primary-fixed" : "bg-surface-bright text-on-surface-variant") px-2 py-0.5 rounded font-label text-[10px] font-bold">@player.Position</span>
                        </div>
                    </div>

                    <!-- Player Info -->
                    <div class="flex-1 flex flex-col justify-between min-w-0">
                        <div>
                            <div class="flex justify-between items-start gap-2">
                                <h3 class="font-headline text-2xl font-bold tracking-tight text-on-surface truncate">@player.Name</h3>
                                @if (isScouted)
                                {
                                    <span class="material-symbols-outlined text-primary flex-shrink-0" style="font-variation-settings:'FILL' 1;">verified</span>
                                }
                                else if (isScoutPending)
                                {
                                    <span class="material-symbols-outlined text-[#eab308] flex-shrink-0 scout-pulse">hourglass_top</span>
                                }
                                else
                                {
                                    <span class="material-symbols-outlined text-outline-variant flex-shrink-0">help</span>
                                }
                            </div>
                            <p class="font-label text-sm text-on-surface-variant uppercase tracking-widest mt-1">@player.Age YAŞINDA • @player.Nationality</p>

                            <!-- Stats Rings -->
                            <div class="grid grid-cols-2 gap-3 mt-4">
                                <!-- OVR Ring -->
                                <div class="flex flex-col items-center p-3 rounded-2xl bg-surface-container-low border border-outline-variant/10">
                                    <div class="relative w-14 h-14 flex items-center justify-center">
                                        <svg class="w-full h-full -rotate-90"><circle class="text-surface-bright" cx="28" cy="28" fill="transparent" r="24" stroke="currentColor" stroke-width="3.5"></circle><circle class="text-primary" cx="28" cy="28" fill="transparent" r="24" stroke="currentColor" stroke-dasharray="150.8" stroke-dashoffset="@(150.8 - (150.8 * player.Ovr / 100.0))" stroke-width="3.5"></circle></svg>
                                        @if (isScouted)
                                        {
                                            <span class="absolute font-headline text-lg font-bold text-primary">@player.Ovr</span>
                                        }
                                        else
                                        {
                                            <span class="absolute font-headline text-lg font-bold text-on-surface-variant">@player.Ovr</span>
                                        }
                                    </div>
                                    <span class="font-label text-[10px] text-on-surface-variant mt-1.5 uppercase">GÜNCEL</span>
                                </div>
                                <!-- Potential Ring -->
                                <div class="flex flex-col items-center p-3 rounded-2xl bg-surface-container-low border border-outline-variant/10 @(!isScouted ? "opacity-50" : "")">
                                    @if (isScouted)
                                    {
                                        <div class="relative w-14 h-14 flex items-center justify-center">
                                            <svg class="w-full h-full -rotate-90"><circle class="text-surface-bright" cx="28" cy="28" fill="transparent" r="24" stroke="currentColor" stroke-width="3.5"></circle><circle class="text-tertiary" cx="28" cy="28" fill="transparent" r="24" stroke="currentColor" stroke-dasharray="150.8" stroke-dashoffset="@(150.8 - (150.8 * player.Potential / 100.0))" stroke-width="3.5"></circle></svg>
                                            <span class="absolute font-headline text-lg font-bold text-tertiary">@player.Potential</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="relative w-14 h-14 flex items-center justify-center border-2 border-dashed border-outline-variant rounded-full">
                                            <span class="font-headline text-lg font-bold text-outline">???</span>
                                        </div>
                                    }
                                    <span class="font-label text-[10px] text-on-surface-variant mt-1.5 uppercase">POTANSİYEL</span>
                                </div>
                            </div>
                        </div>

                        <!-- Value & Action -->
                        <div class="mt-4 flex flex-col gap-3">
                            <div class="flex justify-between items-end">
                                @if (isScouted)
                                {
                                    <div class="flex flex-col">
                                        <span class="font-label text-xs text-on-surface-variant uppercase">PİYASA DEĞERİ</span>
                                        <span class="font-headline text-xl font-bold text-on-surface">@(player.Value >= 1000000 ? $"{player.Value / 1000000.0:0.#}M" : $"{player.Value / 1000}K") €</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="flex flex-col">
                                        <span class="font-label text-[8px] text-error uppercase font-bold tracking-tighter">TAHMİNİ DEĞER</span>
                                        @{
                                            var estimateLow = (int)(player.Value * 0.7);
                                            var estimateHigh = (int)(player.Value * 1.4);
                                        }
                                        <span class="font-headline text-xl font-bold text-on-surface/80">@(estimateLow >= 1000000 ? $"{estimateLow / 1000000.0:0.#}M" : $"{estimateLow / 1000}K") - @(estimateHigh >= 1000000 ? $"{estimateHigh / 1000000.0:0.#}M" : $"{estimateHigh / 1000}K") €</span>
                                    </div>
                                }
                            </div>

                            @if (isScouted)
                            {
                                @if (isWindowOpen)
                                {
                                    <!-- Transfer Offer Form -->
                                    <form method="post" asp-action="MakeOffer" asp-controller="Transfer" class="flex gap-2">
                                        <input type="hidden" name="playerId" value="@player.Id" />
                                        <input name="offerAmount" type="number" min="0" step="100000" value="@player.Value" class="flex-1 bg-surface-container rounded-xl py-3 px-4 font-label text-sm text-on-surface border border-outline-variant/20 focus:ring-2 focus:ring-primary/30" placeholder="Teklif (€)" />
                                        <button type="submit" class="px-6 py-3 bg-primary text-on-primary-fixed rounded-xl font-headline font-bold text-sm uppercase tracking-wider hover:brightness-110 active:scale-95 transition-all shadow-[0_0_20px_rgba(142,255,113,0.2)]">TEKLİF YAP</button>
                                    </form>
                                }
                                else
                                {
                                    <div class="w-full py-3 bg-error/10 border border-error/30 rounded-xl font-headline font-bold uppercase tracking-widest text-center text-error text-sm">
                                        TRANSFER DÖNEMİ KAPALI
                                    </div>
                                }
                            }
                            else if (isScoutPending)
                            {
                                <div class="w-full py-3 bg-[#eab308]/10 border border-[#eab308]/30 rounded-xl font-headline font-bold uppercase tracking-widest text-center text-[#eab308] text-sm scout-pulse">
                                    GÖZLEMLENİYOR... (@daysRemaining GÜN KALDI)
                                </div>
                            }
                            else
                            {
                                @if (isWindowOpen)
                                {
                                    <form method="post" asp-action="ScoutPlayer" asp-controller="Transfer">
                                        <input type="hidden" name="playerId" value="@player.Id" />
                                        <button type="submit" class="w-full py-3 bg-[#eab308]/10 border border-[#eab308]/30 rounded-xl font-headline font-bold uppercase tracking-widest hover:bg-[#eab308]/20 active:scale-95 transition-all text-[#eab308] text-sm">GÖZLEMLE</button>
                                    </form>
                                }
                                else
                                {
                                    <div class="w-full py-3 bg-error/10 border border-error/30 rounded-xl font-headline font-bold uppercase tracking-widest text-center text-error text-sm">
                                        TRANSFER DÖNEMİ KAPALI
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Stats Panels -->
    <section class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="glass-panel p-6 rounded-3xl border border-outline-variant/10">
            <h4 class="font-label text-xs font-bold text-primary tracking-widest uppercase mb-4">Gözlemci Durumu</h4>
            <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-outline-variant/5">
                    <span class="font-body text-sm text-on-surface-variant">Aktif Görevler</span>
                    <span class="font-label text-sm text-on-surface font-bold">@Model.PendingScoutCount / 3</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-outline-variant/5">
                    <span class="font-body text-sm text-on-surface-variant">Tamamlanan Raporlar</span>
                    <span class="font-label text-sm text-on-surface font-bold">@Model.ScoutReports.Count(r => r.IsCompleted)</span>
                </div>
            </div>
        </div>
        <div class="glass-panel p-6 rounded-3xl border border-outline-variant/10">
            <h4 class="font-label text-xs font-bold text-tertiary tracking-widest uppercase mb-4">Finansal Durum</h4>
            <div class="space-y-2">
                @{
                    var totalWages = 0; // Would need a query but keeping simple
                }
                <div class="flex justify-between items-center py-2">
                    <span class="font-body text-sm text-on-surface-variant">Transfer Bütçesi</span>
                    <span class="font-label text-sm text-primary font-bold">@Model.MyTeam.Budget.ToString("N0") €</span>
                </div>
                <div class="flex justify-between items-center py-2">
                    <span class="font-body text-sm text-on-surface-variant">Takım Yıldızı</span>
                    <span class="font-label text-sm text-on-surface font-bold">@Model.MyTeam.RequiredStarRating ★</span>
                </div>
            </div>
        </div>
        <div class="glass-panel p-6 rounded-3xl border border-outline-variant/10 flex items-center justify-between">
            <div>
                <h4 class="font-label text-xs font-bold text-on-surface-variant tracking-widest uppercase mb-1">Oyuncu Havuzu</h4>
                <p class="font-headline text-2xl font-bold">@Model.AvailablePlayers.Count Oyuncu</p>
                <p class="font-label text-[10px] text-on-surface-variant mt-1">Filtrelenen oyuncu sayısı</p>
            </div>
            <span class="material-symbols-outlined text-primary text-4xl">groups</span>
        </div>
    </section>
</main>

@section Scripts {
    <script>
        // Auto-dismiss toast
        document.addEventListener('DOMContentLoaded', function() {
            const toast = document.getElementById('transfer-toast');
            if (toast) {
                setTimeout(() => {
                    toast.style.opacity = '0';
                    setTimeout(() => toast.remove(), 300);
                }, 4000);
            }
        });
    </script>
}
