@model AltLigMenajer.Models.TeamProfileViewModel
@{
    ViewData["Title"] = Model.Team.Name + " - Takım Profili";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
<style>
.glass-panel { background: rgba(26,26,26,0.6); backdrop-filter: blur(20px); border: 1px solid rgba(72,72,71,0.2); }
</style>
}

<header class="fixed top-0 z-50 w-full bg-[#0e0e0e] flex items-center px-4 py-4 bg-gradient-to-b from-[#1a1a1a] to-transparent">
    <a href="javascript:history.back()" class="mr-4 w-10 h-10 flex items-center justify-center rounded-full bg-surface-container-high border border-outline-variant/20 hover:text-primary transition-colors">
        <span class="material-symbols-outlined">arrow_back</span>
    </a>
    <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-primary/20 flex items-center justify-center rounded-xl border border-primary/30">
            <span class="text-sm font-black text-primary">@Model.Team.Name[..Math.Min(3, Model.Team.Name.Length)].ToUpper()</span>
        </div>
        <div>
            <h1 class="font-headline text-lg font-bold uppercase tracking-tighter text-on-surface">@Model.Team.Name</h1>
            <span class="font-label text-[10px] text-on-surface-variant uppercase tracking-widest">TAKIM PROFİLİ</span>
        </div>
    </div>
</header>

<main class="pt-24 pb-32 px-4 max-w-5xl mx-auto min-h-screen">
    <!-- Header Stats -->
    <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="glass-panel p-4 rounded-2xl flex flex-col items-center justify-center text-center">
            <span class="font-label text-[10px] text-on-surface-variant uppercase tracking-widest mb-1">Takım Gücü</span>
            <span class="font-headline text-2xl font-black text-primary">@Model.Team.Ovr</span>
        </div>
        <div class="glass-panel p-4 rounded-2xl flex flex-col items-center justify-center text-center">
            <span class="font-label text-[10px] text-on-surface-variant uppercase tracking-widest mb-1">İtibar</span>
            <div class="flex text-tertiary">
                @for(int i=0; i<Model.Team.RequiredStarRating; i++){ <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">star</span> }
            </div>
        </div>
        <div class="glass-panel p-4 rounded-2xl flex flex-col items-center justify-center text-center">
            <span class="font-label text-[10px] text-on-surface-variant uppercase tracking-widest mb-1">Diziliş</span>
            <span class="font-headline text-xl font-bold text-on-surface">@Model.Team.Formation</span>
        </div>
        <div class="glass-panel p-4 rounded-2xl flex flex-col items-center justify-center text-center">
            <span class="font-label text-[10px] text-on-surface-variant uppercase tracking-widest mb-1">Oyuncu Sayısı</span>
            <span class="font-headline text-xl font-bold text-on-surface">@Model.Players.Count</span>
        </div>
    </section>

    <!-- Roster Table -->
    <section class="glass-panel rounded-2xl overflow-hidden shadow-2xl">
        <div class="px-6 py-4 border-b border-outline-variant/10 bg-surface-container/50">
            <h2 class="font-headline text-sm font-bold uppercase tracking-widest text-on-surface">A TAKIM KADROSU</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container/20 border-b border-outline-variant/20">
                        <th class="py-3 px-4 font-label text-[10px] text-on-surface-variant uppercase font-bold">MEVKİ</th>
                        <th class="py-3 px-4 font-label text-[10px] text-on-surface-variant uppercase font-bold">OYUNCU</th>
                        <th class="py-3 px-4 font-label text-[10px] text-on-surface-variant uppercase font-bold text-center">YAŞ</th>
                        <th class="py-3 px-4 font-label text-[10px] text-on-surface-variant uppercase font-bold text-center">OVR</th>
                        <th class="py-3 px-4 font-label text-[10px] text-on-surface-variant uppercase font-bold text-right">DEĞER</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant/10">
                    @foreach (var player in Model.Players)
                    {
                        <tr class="hover:bg-white/5 transition-colors">
                            <td class="py-3 px-4">
                                <span class="bg-surface-bright text-on-surface-variant px-2 py-1 rounded font-label text-[10px] font-bold">@player.Position</span>
                            </td>
                            <td class="py-3 px-4">
                                <div class="font-headline font-bold text-sm text-on-surface">@player.Name</div>
                                <div class="font-label text-[10px] text-on-surface-variant uppercase">@player.Nationality</div>
                            </td>
                            <td class="py-3 px-4 text-center text-sm font-medium text-on-surface-variant">@player.Age</td>
                            <td class="py-3 px-4 text-center">
                                <span class="font-headline font-bold text-primary">@player.Ovr</span>
                            </td>
                            <td class="py-3 px-4 text-right font-label text-xs font-bold text-on-surface">
                                @(player.Value >= 1000000 ? $"{player.Value / 1000000.0:0.#}M €" : $"{player.Value / 1000}K €")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</main>

<div class="fixed top-0 left-0 w-full h-screen pointer-events-none overflow-hidden -z-10">
    <div class="absolute -top-1/4 -left-1/4 w-1/2 h-1/2 bg-primary/10 blur-[120px] rounded-full"></div>
    <div class="absolute -bottom-1/4 -right-1/4 w-1/2 h-1/2 bg-tertiary/5 blur-[120px] rounded-full"></div>
</div>
