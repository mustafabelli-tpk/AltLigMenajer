@{
    ViewData["Title"] = "Yönetim Ofisi";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var manager = ViewBag.Manager as AltLigMenajer.Models.Manager;
    var team = ViewBag.Team as AltLigMenajer.Models.Team;
    var currentDate = ViewBag.CurrentDate is DateTime ? (DateTime)ViewBag.CurrentDate : new DateTime(2025, 6, 30);
    var upcomingFixtures = ViewBag.UpcomingFixtures as List<AltLigMenajer.Models.Fixture> ?? new List<AltLigMenajer.Models.Fixture>();
    var nextMatch = upcomingFixtures.FirstOrDefault();
    var recentMessages = ViewBag.RecentMessages as List<AltLigMenajer.Models.Message> ?? new List<AltLigMenajer.Models.Message>();
    var unreadMessagesCount = ViewBag.UnreadMessagesCount ?? 0;
    var formResults = ViewBag.FormResults as List<string> ?? new List<string>();
    var currency = ViewBag.Currency as string ?? "EUR";
    var licenseLabel = ViewBag.LicenseLabel as string ?? "C Lisans";
    var xpProgress = (int)(ViewBag.XpProgress ?? 0);
    var xpCurrent = (int)(ViewBag.XpCurrent ?? 0);
    var xpNextThreshold = (int)(ViewBag.XpNextThreshold ?? 200);
    bool isTransferWindowOpen = ViewBag.IsTransferWindowOpen ?? true;

    string FormatMoney(decimal euroAmount) => AltLigMenajer.Helpers.CurrencyHelper.FormatMoney(euroAmount, currency);
}
@section Styles {
<style>
.glass-panel { background: rgba(38,38,38,0.6); backdrop-filter: blur(20px); }
</style>
}

@if (TempData["Notification"] != null)
{
    <div class="bg-error/10 border border-error/20 text-error px-6 py-4 mx-6 mt-4 rounded-xl font-bold flex items-center justify-between">
        <span>@TempData["Notification"]</span>
        <button onclick="this.parentElement.style.display='none'" class="material-symbols-outlined text-error hover:opacity-75">close</button>
    </div>
}

<header class="flex justify-between items-center px-6 py-4 bg-gradient-to-b from-[#1a1a1a] to-transparent">
    <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full overflow-hidden border border-primary/20 bg-surface-container-high flex items-center justify-center">
            <span class="material-symbols-outlined text-on-surface-variant">person</span>
        </div>
        <div>
            <span class="font-headline font-bold text-sm tracking-tight text-on-surface uppercase block">@(manager?.FirstName) @(manager?.LastName)</span>
            <div class="flex items-center gap-2">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-primary/15 border border-primary/30 rounded text-[9px] font-black text-primary uppercase tracking-widest">
                    <span class="material-symbols-outlined text-[10px]">workspace_premium</span>
                    @licenseLabel
                </span>
                <span class="font-label text-[9px] text-on-surface-variant">LV @(manager?.LicenseLevel ?? 1)</span>
            </div>
        </div>
    </div>
    <div class="flex flex-col items-end gap-1">
        <div class="flex items-center gap-3">
            <span class="font-label text-[12px] font-bold text-on-surface">@currentDate.ToString("dd/MM/yyyy")</span>
            <button class="text-primary hover:opacity-80 transition-opacity active:scale-95" onclick="saveGame()" title="Oyunu Kaydet"><span class="material-symbols-outlined">save</span></button>
            <button onclick="document.getElementById('settingsModal').classList.remove('hidden')" class="bg-gray-700 hover:bg-gray-600 text-white font-bold py-2 px-4 rounded ml-4">Ayarlar</button>
        </div>
        @if (isTransferWindowOpen)
        {
            <div class="bg-primary/10 px-2 py-0.5 rounded flex items-center gap-1 border border-primary/20">
                <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
                <span class="font-label text-[9px] text-primary font-bold tracking-widest uppercase">TRANSFER DÖNEMİ AÇIK</span>
            </div>
        }
        else
        {
            <div class="bg-error/10 px-2 py-0.5 rounded flex items-center gap-1 border border-error/20">
                <span class="material-symbols-outlined text-error text-[10px]">lock</span>
                <span class="font-label text-[9px] text-error font-bold tracking-widest uppercase">TRANSFER DÖNEMİ KAPALI</span>
            </div>
        }
    </div>
</header>

<main class="px-6 pb-32 space-y-6">
    <section class="mt-4 flex flex-col md:flex-row md:justify-between md:items-end gap-4">
        <div>
            <h1 class="font-headline font-extrabold text-5xl tracking-tighter text-on-surface uppercase">@(team?.Name ?? "TAKIMSIZ")</h1>
            <div class="flex items-center gap-2 mt-1">
                <span class="font-label text-[10px] text-on-surface-variant uppercase tracking-widest">Son 5 Maç:</span>
                <div class="flex gap-1">
                    @if (formResults.Any())
                    {
                        @foreach (var result in formResults)
                        {
                            var bgColor = result == "G" ? "bg-green-500" : result == "M" ? "bg-red-500" : "bg-gray-500";
                            <span class="w-6 h-6 rounded-md @bgColor flex items-center justify-center text-[10px] font-black text-white shadow-md">@result</span>
                        }
                        @for (int i = formResults.Count; i < 5; i++)
                        {
                            <span class="w-6 h-6 rounded-md bg-outline-variant/30 flex items-center justify-center text-[10px] font-bold text-on-surface-variant">-</span>
                        }
                    }
                    else
                    {
                        @for (int i = 0; i < 5; i++)
                        {
                            <span class="w-6 h-6 rounded-md bg-outline-variant/30 flex items-center justify-center text-[10px] font-bold text-on-surface-variant">-</span>
                        }
                    }
                </div>
            </div>
            <!-- XP Progress Bar -->
            <div class="mt-3 w-full max-w-xs">
                <div class="flex justify-between items-center mb-1">
                    <span class="font-label text-[9px] text-on-surface-variant uppercase tracking-widest">Deneyim (XP)</span>
                    <span class="font-label text-[9px] text-primary font-bold">@xpCurrent / @xpNextThreshold XP</span>
                </div>
                <div class="h-2 w-full bg-surface-container-highest rounded-full overflow-hidden border border-outline-variant/20">
                    <div class="h-full bg-gradient-to-r from-primary-dim to-primary rounded-full transition-all duration-500" style="width:@(xpProgress)%"></div>
                </div>
            </div>
        </div>
        <div class="bg-surface-container p-4 rounded-xl border-l-4 border-primary">
            <p class="font-label text-[10px] text-on-surface-variant uppercase tracking-widest">TRANSFER BÜTÇESİ</p>
            <p class="font-headline font-bold text-2xl text-primary tracking-tight">@FormatMoney(team?.Budget ?? 0)</p>
        </div>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-8">
            <div class="relative overflow-hidden rounded-xl bg-surface-container-high border border-outline-variant/20 p-8 flex flex-col justify-between min-h-[300px]">
                <div class="absolute -right-12 -top-12 text-[12rem] font-headline font-bold opacity-5 select-none uppercase">MATCH</div>
                <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent"></div>
                <div class="relative z-10">
                    <span class="inline-block px-3 py-1 bg-primary text-on-primary-fixed font-label text-[10px] font-bold rounded-full mb-4 uppercase tracking-widest">SIRADAKİ MAÇ</span>
                    @if (nextMatch != null)
                    {
                        var opponentName = nextMatch.HomeTeamId == team?.Id ? nextMatch.AwayTeam?.Name : nextMatch.HomeTeam?.Name;
                        var isHome = nextMatch.HomeTeamId == team?.Id;
                        
                        <h2 class="font-headline font-bold text-4xl text-on-surface tracking-tight uppercase">@opponentName</h2>
                        <p class="font-body text-on-surface-variant mt-2 flex items-center gap-2">
                            <span class="material-symbols-outlined text-sm">calendar_today</span> @nextMatch.MatchDate.ToString("dd/MM/yyyy") • @(isHome ? "Ev Sahibi" : "Deplasman")
                        </p>
                    }
                    else
                    {
                        <h2 class="font-headline font-bold text-2xl text-on-surface-variant tracking-tight uppercase">Planlanmış Maç Yok</h2>
                    }
                </div>
                <div class="relative z-10 flex flex-col md:flex-row items-center gap-8 mt-12">
                    <div class="flex-1 w-full">
                        <div class="flex justify-between items-end mb-2">
                            <span class="font-label text-[10px] text-on-surface-variant uppercase tracking-widest">Takım Hazırlığı</span>
                            <span class="font-headline text-primary font-bold">85%</span>
                        </div>
                        <div class="h-1 w-full bg-surface-container-highest rounded-full overflow-hidden">
                            <div class="h-full bg-primary rounded-full" style="width:85%"></div>
                        </div>
                    </div>
                    @if (nextMatch != null && nextMatch.MatchDate.Date == currentDate.Date && !nextMatch.IsPlayed)
                    {
                        <a href="@Url.Action("Play", "Match", new { id = nextMatch.Id })"
                           class="w-full md:w-auto flex items-center justify-center gap-3 bg-gradient-to-r from-primary to-primary-dim text-on-primary-fixed px-10 py-5 rounded-xl font-headline font-black text-xl shadow-[0_0_30px_rgba(142,255,113,0.35)] hover:shadow-[0_0_50px_rgba(142,255,113,0.6)] transition-all active:scale-95 animate-pulse"
                           style="animation-duration: 2s;">
                            MAÇA ÇIK <span class="material-symbols-outlined font-black">sports_soccer</span>
                        </a>
                    }
                    else
                    {
                        <form asp-controller="Home" asp-action="AdvanceDay" method="post" class="w-full md:w-auto">
                            <button type="submit" class="w-full md:w-auto flex items-center justify-center gap-3 bg-primary text-on-primary-fixed px-10 py-5 rounded-xl font-headline font-black text-xl hover:shadow-[0_0_25px_rgba(142,255,113,0.4)] transition-all active:scale-95">
                                İLERLE <span class="material-symbols-outlined font-black">double_arrow</span>
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
        <div class="lg:col-span-4 space-y-6">
            <div class="bg-surface-container rounded-xl p-5 border border-outline-variant/10">
                <a href="@Url.Action("Index", "Fixture")" class="flex justify-between items-center mb-6 group">
                    <h3 class="font-label text-xs font-bold text-on-surface uppercase tracking-[0.2em] group-hover:text-primary transition-colors">YAKLAŞAN FİKSTÜR</h3>
                    <span class="material-symbols-outlined text-on-surface-variant text-lg group-hover:text-primary transition-colors">event_note</span>
                </a>
                <div class="space-y-4">
                    @foreach (var fixture in upcomingFixtures.Skip(1).Take(3))
                    {
                        var opponentName = fixture.HomeTeamId == team?.Id ? fixture.AwayTeam?.Name : fixture.HomeTeam?.Name;
                        <div class="flex items-center justify-between p-3 bg-surface-container-high rounded-lg hover:bg-surface-bright transition-colors">
                            <div><span class="font-label text-[10px] text-on-surface-variant block">@fixture.MatchDate.ToString("dd/MM/yyyy")</span><span class="font-body font-bold text-sm text-on-surface">@opponentName</span></div>
                            <span class="font-headline font-bold text-on-surface-variant">-</span>
                        </div>
                    }
                    @if (upcomingFixtures.Count <= 1)
                    {
                        <div class="text-on-surface-variant text-sm p-3">Başka maç bulunmuyor.</div>
                    }
                </div>
            </div>
            
            <div class="bg-surface-container rounded-xl p-5 border border-outline-variant/10">
                <a href="@Url.Action("Index", "Inbox")" class="flex justify-between items-center mb-6 group">
                    <h3 class="font-label text-xs font-bold text-on-surface uppercase tracking-[0.2em] group-hover:text-primary transition-colors">GELEN KUTUSU</h3>
                    <div class="relative">
                        <span class="material-symbols-outlined text-on-surface-variant text-lg group-hover:text-primary transition-colors">mail</span>
                        @if (unreadMessagesCount > 0)
                        {
                            <span class="absolute -top-1 -right-1 w-3 h-3 bg-error text-on-error flex items-center justify-center text-[8px] font-bold rounded-full">@unreadMessagesCount</span>
                        }
                    </div>
                </a>
                <div class="space-y-3">
                    @foreach (var message in recentMessages)
                    {
                        var isUnread = !message.IsRead;
                        <div class="flex items-start gap-3 p-3 bg-surface-container-low rounded-lg @(isUnread ? "border-l-2 border-primary" : "") cursor-pointer hover:bg-surface-bright transition-colors" onclick="window.location.href='@Url.Action("Index", "Inbox")'">
                            <div class="w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center flex-shrink-0">
                                <span class="material-symbols-outlined text-on-surface-variant text-sm">@(message.Sender.Contains("Sağlık") ? "medical_services" : message.Sender.Contains("TFF") ? "emoji_events" : "corporate_fare")</span>
                            </div>
                            <div class="overflow-hidden">
                                <span class="font-label text-[10px] @(isUnread ? "text-primary" : "text-on-surface-variant") font-bold uppercase block truncate">@message.Sender</span>
                                <p class="text-[12px] text-on-surface font-medium truncate">@message.Subject</p>
                            </div>
                        </div>
                    }
                    @if (!recentMessages.Any())
                    {
                        <div class="text-on-surface-variant text-sm p-3">Mesaj yok.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</main>
<div class="fixed top-0 right-0 w-64 h-64 bg-primary/5 blur-[120px] pointer-events-none -z-10"></div>
<div class="fixed bottom-0 left-0 w-96 h-96 bg-primary/5 blur-[150px] pointer-events-none -z-10"></div>

<!-- Settings Modal -->
<div id="settingsModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="toggleSettings()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-sm bg-surface-container-high border border-outline-variant/30 rounded-3xl shadow-[0_0_50px_rgba(0,0,0,0.8)] overflow-hidden transition-all duration-300" id="settingsModalContent">
        <div class="bg-gradient-to-r from-primary/20 to-transparent p-6 border-b border-outline-variant/20 flex justify-between items-center">
            <div>
                <h2 class="font-headline font-black text-xl text-on-surface tracking-tight">AYARLAR</h2>
                <p class="font-label text-[10px] text-on-surface-variant uppercase tracking-widest">Sistem Tercihleri</p>
            </div>
            <button onclick="toggleSettings()" class="w-8 h-8 flex items-center justify-center rounded-full bg-surface-container-highest hover:bg-error/20 hover:text-error transition-colors">
                <span class="material-symbols-outlined text-sm">close</span>
            </button>
        </div>
        
        <div class="p-6 space-y-6">
            <!-- Currency Toggle -->
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center border border-outline-variant/20">
                        <span class="material-symbols-outlined text-on-surface-variant">payments</span>
                    </div>
                    <div>
                        <p class="font-headline font-bold text-sm text-on-surface">Para Birimi</p>
                        <p class="font-label text-[10px] text-on-surface-variant">Gösterim formatı</p>
                    </div>
                </div>
                <div class="flex p-1 bg-surface-container-highest rounded-lg border border-outline-variant/20">
                    <form method="post" asp-controller="Home" asp-action="SetCurrency" style="display:inline;">
                        <input type="hidden" name="currency" value="EUR" />
                        <button type="submit" class="px-4 py-1.5 rounded @(currency == "EUR" ? "bg-primary text-on-primary-fixed shadow-md" : "text-on-surface-variant hover:text-on-surface") font-headline font-bold text-xs transition-all">€ Euro</button>
                    </form>
                    <form method="post" asp-controller="Home" asp-action="SetCurrency" style="display:inline;">
                        <input type="hidden" name="currency" value="TL" />
                        <button type="submit" class="px-4 py-1.5 rounded @(currency == "TL" ? "bg-primary text-on-primary-fixed shadow-md" : "text-on-surface-variant hover:text-on-surface") font-headline font-bold text-xs transition-all">₺ TL</button>
                    </form>
                </div>
            </div>

            <!-- Simulation Speed -->
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center border border-outline-variant/20">
                        <span class="material-symbols-outlined text-on-surface-variant">speed</span>
                    </div>
                    <div>
                        <p class="font-headline font-bold text-sm text-on-surface">Simülasyon Hızı</p>
                        <p class="font-label text-[10px] text-on-surface-variant">Maç işleme hızı</p>
                    </div>
                </div>
                <select class="bg-surface-container-highest border border-outline-variant/20 rounded-lg text-xs font-bold px-3 py-2 text-on-surface outline-none">
                    <option>Yavaş</option>
                    <option selected>Normal</option>
                    <option>Hızlı</option>
                </select>
            </div>
            
            <!-- Auto-Save -->
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-surface-container-highest flex items-center justify-center border border-outline-variant/20">
                        <span class="material-symbols-outlined text-on-surface-variant">save_as</span>
                    </div>
                    <div>
                        <p class="font-headline font-bold text-sm text-on-surface">Otomatik Kayıt</p>
                        <p class="font-label text-[10px] text-on-surface-variant">Hafta atlamalarında</p>
                    </div>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" class="sr-only peer" checked>
                    <div class="w-11 h-6 bg-surface-container-highest peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                </label>
            </div>
        </div>
        
        <div class="p-4 bg-surface-container/50 border-t border-outline-variant/10">
            <button onclick="toggleSettings()" class="w-full bg-surface-container-highest hover:bg-surface-bright border border-outline-variant/20 text-on-surface font-headline font-bold py-3 rounded-xl transition-colors">
                Kapat
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function saveGame() {
            fetch('@Url.Action("SaveGame", "Home")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                if(data.success) {
                    showToast(data.message);
                }
            })
            .catch(error => console.error('Error:', error));
        }

        function showToast(message) {
            const toast = document.createElement('div');
            toast.className = 'fixed top-20 right-6 bg-primary/20 text-primary border border-primary/40 px-6 py-4 rounded-xl font-bold flex items-center gap-3 z-[100] shadow-[0_0_15px_rgba(142,255,113,0.2)] transition-opacity duration-300';
            toast.innerHTML = `<span class="material-symbols-outlined">check_circle</span><span>${message}</span>`;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.style.opacity = '0';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }
        function toggleSettings() {
            const modal = document.getElementById('settingsModal');
            if (modal.classList.contains('hidden')) {
                modal.classList.remove('hidden');
            } else {
                modal.classList.add('hidden');
            }
        }
    </script>
}
