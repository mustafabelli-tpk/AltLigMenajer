@model AltLigMenajer.Models.Player

@{
    ViewData["Title"] = Model.Name + " - Oyuncu Profili";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
    <style>
        .glass-panel {
            background: rgba(38, 38, 38, 0.6);
            backdrop-filter: blur(20px);
        }
        .radial-progress {
            position: relative;
            display: inline-grid;
            place-content: center;
        }
        .radial-progress::before {
            content: "";
            position: absolute;
            border-radius: 50%;
            inset: 0;
            background: conic-gradient(currentColor calc(var(--value) * 1%), #1a1a1a 0);
            mask: radial-gradient(farthest-side, transparent calc(100% - 6px), #fff calc(100% - 5px));
        }
    </style>
}

<div class="bg-surface text-on-surface font-body min-h-screen pb-32">
<!-- Top Navigation Anchor -->
<header class="bg-[#0e0e0e]/80 backdrop-blur-xl flex justify-between items-center px-6 h-16 w-full docked full-width top-0 sticky z-50 bg-gradient-to-b from-[#1a1a1a] to-transparent shadow-none">
    <div class="flex items-center gap-3">
        <a href="@Url.Action("Index", "Squad")"><span class="material-symbols-outlined text-[#39FF14] cursor-pointer hover:opacity-80 transition-opacity" data-icon="arrow_back">arrow_back</span></a>
        <div class="w-8 h-8 rounded-full bg-surface-container-highest border border-outline-variant/20 flex items-center justify-center overflow-hidden">
            <span class="material-symbols-outlined text-on-surface-variant">person</span>
        </div>
        <h1 class="font-['Space_Grotesk'] uppercase tracking-widest font-bold text-[#8eff71] font-black tracking-tighter text-xl">@(Model.Team?.Name ?? "TAKIM")</h1>
    </div>
</header>

<main class="px-5 pt-4 space-y-6">
<!-- Upper Section: Profile & Rings -->
<section class="flex items-center justify-between gap-4">
<div class="relative group">
<div class="w-32 h-32 rounded-full ring-4 ring-primary/20 ring-offset-4 ring-offset-surface overflow-hidden bg-surface-container-high flex items-center justify-center">
<span class="material-symbols-outlined text-6xl text-on-surface-variant">person</span>
</div>
<div class="absolute -bottom-2 -right-2 bg-primary text-on-primary-fixed px-3 py-1 rounded-full font-headline font-bold text-xs uppercase shadow-lg">
                    @Model.Position
                </div>
</div>
<div class="flex-1 space-y-3">
<div class="space-y-0.5">
<h2 class="font-headline font-bold text-2xl tracking-tighter leading-none">@Model.Name</h2>
<p class="font-label text-on-surface-variant text-sm tracking-widest uppercase">@Model.Age YAŞINDA • @(string.IsNullOrEmpty(Model.Nationality) ? "BİLİNMİYOR" : Model.Nationality.ToUpper())</p>
</div>
<div class="flex gap-4">
<div class="flex flex-col items-center gap-1">
<div class="radial-progress w-16 h-16 text-primary" role="progressbar" style="--value:@Model.Ovr">
<span class="font-headline font-bold text-lg">@Model.Ovr</span>
</div>
<span class="font-label text-[10px] text-on-surface-variant tracking-widest uppercase">OVR</span>
</div>
<div class="flex flex-col items-center gap-1">
<div class="radial-progress w-16 h-16 text-tertiary" role="progressbar" style="--value:@Model.Potential">
<span class="font-headline font-bold text-lg">@Model.Potential</span>
</div>
<span class="font-label text-[10px] text-on-surface-variant tracking-widest uppercase">POT</span>
</div>
</div>
</div>
</section>

<!-- Core Attributes: Bento Style -->
<section class="space-y-4">
<div class="flex justify-between items-end">
<h3 class="font-headline text-primary text-sm font-bold tracking-[0.2em] uppercase">TEMEL ÖZELLİKLER</h3>
<span class="font-label text-[10px] text-on-surface-variant">TEKNİK VERİLER</span>
</div>
<div class="grid grid-cols-1 gap-3">
<!-- Hız -->
<div class="bg-surface-container-high p-4 rounded-xl space-y-3 border-l-2 border-primary/40">
<div class="flex justify-between items-center">
<span class="font-label text-xs uppercase tracking-wider flex items-center gap-2">
                            🚀 Hız
                        </span>
<span class="font-headline font-bold text-primary">@(Math.Min(Model.Ovr + 4, 99))</span>
</div>
<div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-primary rounded-full relative" style="width: @(Math.Min(Model.Ovr + 4, 99))%">
<div class="absolute right-0 top-0 h-full w-1 bg-white/40"></div>
</div>
</div>
</div>
<!-- Güç -->
<div class="bg-surface-container-high p-4 rounded-xl space-y-3 border-l-2 border-primary/20">
<div class="flex justify-between items-center">
<span class="font-label text-xs uppercase tracking-wider flex items-center gap-2">
                            💪 Güç
                        </span>
<span class="font-headline font-bold text-primary">@(Math.Max(Model.Ovr - 3, 0))</span>
</div>
<div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-primary rounded-full relative" style="width: @(Math.Max(Model.Ovr - 3, 0))%">
<div class="absolute right-0 top-0 h-full w-1 bg-white/40"></div>
</div>
</div>
</div>
<!-- Bitiricilik -->
<div class="bg-surface-container-high p-4 rounded-xl space-y-3 border-l-2 border-primary/20">
<div class="flex justify-between items-center">
<span class="font-label text-xs uppercase tracking-wider flex items-center gap-2">
                            🎯 Bitiricilik
                        </span>
<span class="font-headline font-bold text-primary">@Model.Ovr</span>
</div>
<div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-primary rounded-full relative" style="width: @Model.Ovr%">
<div class="absolute right-0 top-0 h-full w-1 bg-white/40"></div>
</div>
</div>
</div>
<!-- Pas -->
<div class="bg-surface-container-high p-4 rounded-xl space-y-3 border-l-2 border-primary/60">
<div class="flex justify-between items-center">
<span class="font-label text-xs uppercase tracking-wider flex items-center gap-2">
                            ⚽ Pas
                        </span>
<span class="font-headline font-bold text-primary">@(Math.Min(Model.Ovr + 10, 99))</span>
</div>
<div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-primary rounded-full relative" style="width: @(Math.Min(Model.Ovr + 10, 99))%">
<div class="absolute right-0 top-0 h-full w-1 bg-white/40"></div>
</div>
</div>
</div>
</div>
</section>

<!-- Club Info -->
<section class="space-y-4">
<h3 class="font-headline text-primary text-sm font-bold tracking-[0.2em] uppercase">KULÜP BİLGİLERİ</h3>
<div class="grid grid-cols-2 gap-3">
<div class="bg-surface-container p-4 rounded-xl border border-white/5">
<p class="font-label text-[10px] text-on-surface-variant uppercase tracking-tighter">Piyasa Değeri</p>
<p class="font-headline font-bold text-lg">@Model.Value.ToString("N0") €</p>
</div>
<div class="bg-surface-container p-4 rounded-xl border border-white/5">
<p class="font-label text-[10px] text-on-surface-variant uppercase tracking-tighter">Sözleşme Bitiş</p>
<p class="font-headline font-bold text-lg">@Model.ContractEndDate.Year</p>
</div>
<div class="col-span-2 bg-surface-container p-4 rounded-xl border border-white/5 flex justify-between items-center">
<div>
<p class="font-label text-[10px] text-on-surface-variant uppercase tracking-tighter">Maaş (Yıllık)</p>
<p class="font-headline font-bold text-lg">@Model.Wage.ToString("N0") €</p>
</div>
<span class="text-3xl">💰</span>
</div>
<div class="col-span-2 bg-surface-container p-4 rounded-xl border border-white/5 flex justify-between items-center">
<div>
<p class="font-label text-[10px] text-on-surface-variant uppercase tracking-tighter">Moral Durumu</p>
<p class="font-body font-medium text-on-surface">Harika</p>
</div>
<span class="text-3xl">😃</span>
</div>
</div>
</section>

<!-- Action Buttons -->
<section class="flex flex-col gap-3 py-4">
    @if (TempData["Notification"] != null)
    {
        <div class="bg-primary/20 text-primary border border-primary/40 px-4 py-3 rounded-xl mb-2 text-center text-sm font-bold font-headline shadow-[0_0_15px_rgba(142,255,113,0.1)]">
            @TempData["Notification"]
        </div>
    }

    @if (Model.IsTransferListed)
    {
        <form asp-controller="Squad" asp-action="RemoveFromTransferList" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="w-full bg-error text-white hover:bg-error/90 transition-all py-4 px-6 rounded-xl font-headline font-bold text-sm tracking-widest flex items-center justify-center gap-3 active:scale-95 shadow-[0_0_20px_rgba(213,61,24,0.3)]">
                <span class="material-symbols-outlined" data-icon="cancel">cancel</span>
                TRANSFER LİSTESİNDEN KALDIR
            </button>
        </form>
    }
    else
    {
        <form asp-controller="Squad" asp-action="ListForTransfer" method="post" class="flex flex-col gap-2">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="flex gap-2">
                <input type="number" name="askingPrice" placeholder="Bonservis (Örn: 5000000)" class="bg-surface-container-highest text-on-surface px-4 py-4 rounded-xl flex-1 outline-none border border-outline-variant/20 focus:border-primary/50 text-sm font-label font-bold" required />
                <button type="submit" class="bg-error-dim hover:bg-error transition-all py-4 px-6 rounded-xl font-headline font-bold text-sm tracking-widest flex items-center justify-center gap-3 active:scale-95 shadow-[0_0_20px_rgba(213,61,24,0.2)] text-white whitespace-nowrap">
                    <span class="material-symbols-outlined" data-icon="list_alt">list_alt</span>
                    SAT
                </button>
            </div>
        </form>
    }

    @if (Model.IsLoanListed)
    {
        <div class="bg-tertiary/20 text-tertiary border border-tertiary/40 px-4 py-3 rounded-xl font-headline font-bold text-sm tracking-widest text-center">
            KİRALIK LİSTESİNDE
        </div>
    }
    else
    {
        <form asp-controller="Squad" asp-action="ListForLoan" method="post">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="w-full bg-tertiary-dim text-on-tertiary-container hover:bg-tertiary transition-all py-4 px-6 rounded-xl font-headline font-bold text-sm tracking-widest flex items-center justify-center gap-3 active:scale-95">
                <span class="material-symbols-outlined" data-icon="handshake">handshake</span>
                KİRALIK LİSTESİNE EKLE
            </button>
        </form>
    }

    <a href="@Url.Action("RenewContract", "Squad", new { id = Model.Id })" class="w-full bg-primary text-on-primary-fixed hover:bg-primary/90 transition-all py-4 px-6 rounded-xl font-headline font-bold text-sm tracking-widest flex items-center justify-center gap-3 active:scale-95 shadow-[0_0_20px_rgba(142,255,113,0.2)]">
        <span class="material-symbols-outlined" data-icon="history_edu">history_edu</span>
        SÖZLEŞME YENİLE
    </a>
</section>
</main>
</div>
