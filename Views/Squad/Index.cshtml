@model IEnumerable<AltLigMenajer.Models.Player>
@{
    ViewData["Title"] = "Takım Kadrosu";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var teamName = Model.FirstOrDefault()?.Team?.Name ?? "TAKIM KADROSU";
    var avgOvr = Model.Any() ? (int)Model.Average(p => p.Ovr) : 0;
}
<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 bg-gradient-to-b from-[#1a1a1a] to-transparent">
    <div class="flex justify-between items-center px-6 py-4 w-full">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-2xl">sports_soccer</span>
            <div>
                <h1 class="text-2xl font-bold tracking-tighter text-[#8eff71] font-headline uppercase">@teamName</h1>
                <p class="text-[10px] font-label text-on-surface-variant tracking-widest uppercase">A Takım Kadrosu (@Model.Count() Oyuncu)</p>
            </div>
        </div>
        <div class="bg-surface-container-highest px-3 py-1 rounded-full border border-primary/20 shadow-[0_0_10px_rgba(142,255,113,0.1)]">
            <span class="font-label font-bold text-primary text-sm">OVR: @avgOvr</span>
        </div>
    </div>
</header>

<main class="flex-1 mt-20 mb-28 px-4">
    <div class="flex gap-2 mb-6 overflow-x-auto pb-2">
        <a href="@Url.Action("Index", new { sortOrder = "position" })" class="bg-surface-container-high text-on-surface-variant font-label text-[11px] px-4 py-2 rounded-xl border border-outline-variant/20 flex items-center gap-2 whitespace-nowrap active:scale-95 transition-transform hover:text-primary">
            MEVKİ <span class="material-symbols-outlined text-xs">swap_vert</span>
        </a>
        <a href="@Url.Action("Index")" class="bg-primary/10 text-primary font-label text-[11px] px-4 py-2 rounded-xl border border-primary/30 flex items-center gap-2 whitespace-nowrap active:scale-95 transition-transform">
            OVR <span class="material-symbols-outlined text-xs">arrow_downward</span>
        </a>
        <a href="@Url.Action("Index", new { sortOrder = "fatigue" })" class="bg-surface-container-high text-on-surface-variant font-label text-[11px] px-4 py-2 rounded-xl border border-outline-variant/20 flex items-center gap-2 whitespace-nowrap active:scale-95 transition-transform hover:text-primary">
            YORGUNLUK <span class="material-symbols-outlined text-xs">bolt</span>
        </a>
    </div>

    <div class="space-y-3">
        @foreach (var player in Model)
        {
            var isStar = player.Ovr >= 68;
            var borderColor = isStar ? "border-tertiary" : "border-primary/40";
            var ovrBg = isStar ? "border-primary bg-primary/10 shadow-[0_0_10px_rgba(142,255,113,0.2)]" : "border-primary/50";
            var ovrText = isStar ? "text-primary" : "text-on-surface";
            var positionBg = isStar ? "bg-tertiary/20 border-tertiary/30" : "bg-surface-container-highest border-outline-variant/20";
            var positionText = isStar ? "text-tertiary" : "text-on-surface-variant";

            <a href="@Url.Action("Details", "Squad", new { id = player.Id })" class="block bg-surface-container-high rounded-xl p-4 flex items-center gap-4 border-l-4 @borderColor shadow-lg relative overflow-hidden active:scale-[0.98] transition-all hover:bg-surface-bright">
                @if (isStar)
                {
                    <div class="absolute -right-2 -bottom-4 opacity-5 pointer-events-none"><span class="font-headline font-bold text-7xl text-on-surface italic">10</span></div>
                }
                <div class="flex-shrink-0 w-12 h-12 @positionBg flex items-center justify-center rounded-lg border">
                    <span class="font-label font-bold @positionText text-sm">@player.Position</span>
                </div>
                <div class="flex-1 min-w-0">
                    <h3 class="font-headline font-bold text-lg text-on-surface truncate tracking-tight">@player.Name</h3>
                    <div class="flex items-center gap-3 mt-0.5">
                        <span class="text-[11px] font-label text-on-surface-variant">YAŞ: @(player.Age > 0 ? player.Age : 22)</span>
                        <span class="text-[11px] font-label text-primary font-bold tracking-tight">@(player.Value > 0 ? player.Value.ToString("N0") + " €" : "Bilinmiyor")</span>
                        <span class="text-[11px] font-label text-tertiary">📄 @player.ContractEndDate.Year</span>
                    </div>
                </div>
                <div class="flex flex-col items-end gap-2">
                    <div class="flex items-center gap-1">
                        @if (isStar)
                        {
                            <span class="material-symbols-outlined text-primary text-xs">trending_up</span>
                        }
                        <div class="w-10 h-10 rounded-full border-2 @ovrBg flex items-center justify-center">
                            <span class="font-headline font-bold @ovrText text-lg">@player.Ovr</span>
                        </div>
                    </div>
                    <!-- Fatigue Bar -->
                    <div class="w-12 flex items-center gap-1" title="Yorgunluk: @player.Fatigue%">
                        <span class="material-symbols-outlined text-[10px] @(player.Fatigue > 70 ? "text-error" : player.Fatigue > 40 ? "text-tertiary" : "text-primary")">bolt</span>
                        <div class="flex-1 bg-surface-container-highest h-1.5 rounded-full overflow-hidden">
                            <div class="@(player.Fatigue > 70 ? "bg-error" : player.Fatigue > 40 ? "bg-tertiary" : "bg-primary") h-full w-[@(Math.Min(player.Fatigue, 100))%]"></div>
                        </div>
                    </div>
                </div>
            </a>
        }
    </div>
</main>
