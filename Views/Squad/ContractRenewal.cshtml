@model AltLigMenajer.Models.Player
@{
    ViewData["Title"] = "Sözleşme Yenileme - " + Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<main class="px-4 pt-4 pb-32">
    <!-- Brand / Context Bar -->
    <div class="flex items-center justify-between mb-6">
        <a href="javascript:history.back()" class="w-10 h-10 flex items-center justify-center bg-surface-container rounded-xl hover:bg-surface-container-high transition-colors">
            <span class="material-symbols-outlined text-on-surface">arrow_back_ios_new</span>
        </a>
        <div class="text-center flex-1">
            <h2 class="font-headline font-extrabold text-2xl tracking-tighter italic uppercase">@Model.Name</h2>
        </div>
        <div class="w-10"></div>
    </div>

    <!-- Negotiation Hero -->
    <div class="mb-8 relative">
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-primary/10 blur-[80px] rounded-full"></div>
        <div class="flex flex-col items-center">
            <div class="relative mb-4">
                <div class="w-32 h-32 rounded-full border-4 border-primary/20 p-1 overflow-hidden shadow-[0_0_30px_rgba(142,255,113,0.15)] bg-surface-container-high flex items-center justify-center">
                    <span class="material-symbols-outlined text-6xl text-primary" data-icon="person">person</span>
                </div>
                <div class="absolute -bottom-2 -right-2 w-10 h-10 bg-surface-container-highest rounded-full flex items-center justify-center text-xl shadow-lg border border-outline-variant/50">
                    😃
                </div>
            </div>
            <h3 class="font-headline text-3xl font-bold tracking-tighter text-on-surface uppercase">SÖZLEŞME GÖRÜŞMESİ</h3>
            <div class="flex items-center gap-3 mt-1">
                <span class="font-label text-xs uppercase tracking-widest text-on-surface-variant">Yaş: @Model.Age</span>
                <div class="w-1 h-1 bg-outline-variant rounded-full"></div>
                <span class="font-label text-xs uppercase tracking-widest text-primary font-bold">@Model.Position</span>
            </div>
        </div>
    </div>

    <form method="post" asp-controller="Squad" asp-action="RenewContractPost">
        <input type="hidden" name="playerId" value="@Model.Id" />

        <div class="grid grid-cols-1 gap-4">
            <!-- Current Contract -->
            <section class="bg-surface-container-low rounded-xl p-5 border-l border-t border-outline-variant/10">
                <h5 class="font-label text-[10px] tracking-[0.2em] text-on-surface-variant uppercase mb-4">MEVCUT SÖZLEŞME</h5>
                <div class="space-y-4">
                    <div class="flex justify-between items-center group">
                        <span class="text-sm font-body text-on-surface-variant">Piyasa Değeri</span>
                        <span class="font-headline font-bold text-base">@Model.Value.ToString("N0") €</span>
                    </div>
                    <div class="w-full h-px bg-surface-container-highest/50"></div>
                    <div class="flex justify-between items-center group">
                        <span class="text-sm font-body text-on-surface-variant">Sözleşme Bitiş</span>
                        <span class="font-headline font-bold text-base">@Model.ContractEndDate.Year</span>
                    </div>
                    <div class="w-full h-px bg-surface-container-highest/50"></div>
                    <div class="flex justify-between items-center group">
                        <span class="text-sm font-body text-on-surface-variant">Mevcut Maaş</span>
                        <span class="font-headline font-bold text-base text-tertiary">@Model.Wage.ToString("N0") €/Yıl</span>
                    </div>
                </div>
            </section>

            <!-- New Offer Form -->
            <section class="bg-surface-container-high rounded-xl p-5 shadow-xl border border-primary/5">
                <h5 class="font-label text-[10px] tracking-[0.2em] text-primary uppercase mb-6">YENİ TEKLİF YAP</h5>
                <div class="space-y-8">
                    <!-- Salary Slider -->
                    <div>
                        <div class="flex justify-between mb-3">
                            <label class="font-label text-xs text-on-surface-variant">Yıllık Maaş (€)</label>
                            <span id="wageLabel" class="font-headline font-bold text-primary">@Model.Wage.ToString("N0") €/Yıl</span>
                        </div>
                        <input type="range" id="offeredWage" name="offeredWage" min="10000" max="@(Math.Max(Model.Value, 5000000))" step="10000" value="@Model.Wage" class="w-full h-2 bg-surface-container-highest rounded-full appearance-none outline-none cursor-pointer" style="accent-color: #8eff71;" oninput="updateWageLabel(this.value)" />
                    </div>

                    <!-- Duration Slider -->
                    <div>
                        <div class="flex justify-between mb-3">
                            <label class="font-label text-xs text-on-surface-variant">Uzatılacak Süre (Yıl)</label>
                            <span id="yearsLabel" class="font-headline font-bold text-on-surface">1 Yıl</span>
                        </div>
                        <input type="range" id="offeredYears" name="offeredYears" min="1" max="5" step="1" value="1" class="w-full h-2 bg-surface-container-highest rounded-full appearance-none outline-none cursor-pointer" style="accent-color: #ffffff;" oninput="updateYearsLabel(this.value)" />
                    </div>
                </div>
            </section>
        </div>

        <!-- Sticky Interaction Zone -->
        <div class="mt-8 space-y-3 pb-8">
            <button type="submit" class="w-full py-5 bg-primary rounded-xl flex items-center justify-center gap-3 active:scale-95 transition-all shadow-[0_8px_32px_rgba(142,255,113,0.3)] hover:brightness-110">
                <span class="font-headline font-black text-lg text-on-primary-fixed tracking-tight">TEKLİF YAP</span>
                <span class="material-symbols-outlined text-on-primary-fixed">send</span>
            </button>
            <a href="javascript:history.back()" class="w-full py-4 bg-surface-container-highest rounded-xl flex items-center justify-center gap-2 active:scale-95 transition-all text-on-surface-variant hover:text-on-surface">
                <span class="font-label font-bold text-sm tracking-widest uppercase">VAZGEÇ</span>
            </a>
        </div>
    </form>
</main>

@section Scripts {
    <script>
        function updateWageLabel(value) {
            document.getElementById('wageLabel').innerText = Number(value).toLocaleString('tr-TR') + ' €/Yıl';
        }
        function updateYearsLabel(value) {
            document.getElementById('yearsLabel').innerText = value + ' Yıl';
        }
    </script>
}
