@model AltLigMenajer.Models.Message

@{
    ViewData["Title"] = "Mesajı Oku";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-background pt-8 pb-32 px-6">
    <div class="max-w-4xl mx-auto">
        <a href="@Url.Action("Index", "Inbox")" class="inline-flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors font-label text-xs uppercase font-bold tracking-widest mb-6">
            <span class="material-symbols-outlined text-sm">arrow_back</span> Geri Dön
        </a>

        <div class="bg-surface-container rounded-2xl border border-outline-variant/20 p-8 shadow-2xl relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 blur-[100px] pointer-events-none rounded-full"></div>
            
            <div class="flex items-start justify-between border-b border-outline-variant/20 pb-6 mb-6">
                <div class="flex items-center gap-5">
                    <div class="w-14 h-14 rounded-full bg-surface-container-high flex items-center justify-center flex-shrink-0 text-on-surface">
                        <span class="material-symbols-outlined text-2xl">@(Model.Sender.Contains("Sağlık") ? "medical_services" : "corporate_fare")</span>
                    </div>
                    <div>
                        <h2 class="font-headline font-black text-2xl text-on-surface uppercase tracking-tight">@Model.Sender</h2>
                        <span class="font-body text-sm text-on-surface-variant">@Model.DateSent.ToString("dd MMMM yyyy, dddd")</span>
                    </div>
                </div>
            </div>

            <h1 class="font-headline font-extrabold text-3xl text-on-surface mb-6">@Model.Subject</h1>
            
            <div class="prose prose-invert prose-p:font-body prose-p:text-lg prose-p:leading-relaxed prose-p:text-on-surface-variant max-w-none">
                <p>@Model.Content</p>
            </div>
        </div>
    </div>
</div>
